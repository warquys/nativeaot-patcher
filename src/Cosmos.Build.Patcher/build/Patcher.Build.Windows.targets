<Project>

  <!-- On Windows the patcher is invoked via the .exe in the global tools folder. -->
  <PropertyGroup>
    <CosmosPatcherExe Condition="'$(CosmosPatcherExe)' == ''">$(USERPROFILE)\.dotnet\tools\cosmos.patcher.exe</CosmosPatcherExe>
    <_CosmosPatcherCommand Condition="'$(_CosmosPatcherCommand)' == ''">&quot;$(CosmosPatcherExe)&quot;</_CosmosPatcherCommand>
  </PropertyGroup>

</Project>
